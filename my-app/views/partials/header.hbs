{{! CSS đi kèm (bạn có thể tách ra file riêng) }}
<style>
  /* Reset cơ bản */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: "Helvetica Neue", Arial, sans-serif;
  }

  /* Top Bar */
  .top-bar {
    background-color: #f5f5f5;
    padding: 8px 0;
    border-bottom: 1px solid #e5e5e5;
  }

  .top-bar-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    justify-content: flex-end;
  }

  .top-bar-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .top-link {
    color: #111;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .top-link:hover {
    opacity: 0.6;
  }

  /* Dropdown user */
  .user-dropdown {
    position: relative;
    display: inline-block;
    cursor: pointer;
  }

  .user-greeting {
    color: #111;
    font-weight: 500;
    padding: 6px 12px;
    border-radius: 20px;
    background-color: #fff;
    transition: background 0.2s;
    font-size: 0.8rem;
    border: 1px solid #ddd;
  }

  .user-greeting:hover {
    background-color: #e5e5e5;
  }

  .dropdown-box {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 8px;
    background: white;
    border-radius: 8px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    min-width: 150px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-5px);
    transition: all 0.2s ease;
    z-index: 1000;
    border: 1px solid #e5e5e5;
  }

  .user-dropdown:hover .dropdown-box {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .logout-link {
    display: block;
    padding: 12px 16px;
    text-decoration: none;
    color: #111;
    font-size: 0.9rem;
    transition: background 0.15s;
  }

  .logout-link:hover {
    background: #f5f5f5;
    color: #d32f2f;
  }

  .dropdown-box::before {
    content: "";
    position: absolute;
    top: -6px;
    right: 16px;
    width: 12px;
    height: 12px;
    background: white;
    transform: rotate(45deg);
    border-left: 1px solid #e5e5e5;
    border-top: 1px solid #e5e5e5;
  }

  /* Main Header */
  .main-header {
    background: white;
    padding: 15px 0;
    border-bottom: 1px solid #e5e5e5;
  }

  .main-header-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo a {
    font-size: 2rem;
    font-weight: 800;
    text-decoration: none;
    color: #111;
    letter-spacing: -1px;
  }

  /* Menu chính */
  .main-menu ul {
    display: flex;
    list-style: none;
    gap: 32px;
  }

  .menu-item {
    position: relative;
  }

  .menu-link {
    text-decoration: none;
    color: #111;
    font-weight: 600;
    font-size: 1rem;
    padding: 10px 0;
    display: block;
  }

  .arrow {
    font-size: 0.7rem;
    margin-left: 4px;
  }

  /* Dropdown menu cho Nam/Nữ */
  .has-dropdown .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    background: white;
    min-width: 600px;
    display: flex;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.2s ease;
    z-index: 999;
    border: 1px solid #e5e5e5;
  }

  .has-dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-column {
    flex: 1;
    padding: 0 15px;
  }

  .dropdown-column h4 {
    font-size: 0.9rem;
    margin-bottom: 12px;
    color: #111;
  }

  .dropdown-column ul {
    display: block;
    list-style: none;
  }

  .dropdown-column ul li {
    margin-bottom: 8px;
  }

  .dropdown-column ul li a {
    text-decoration: none;
    color: #757575;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .dropdown-column ul li a:hover {
    color: #111;
  }

  /* Search Box */
  .search-box {
    margin-left: 20px;
  }

  .search-inner {
    display: flex;
    align-items: center;
    background: #f5f5f5;
    border-radius: 30px;
    padding: 5px 10px;
  }

  .search-input {
    border: none;
    background: transparent;
    padding: 8px 12px;
    font-size: 0.9rem;
    outline: none;
    width: 200px;
  }

  .search-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.1rem;
    padding: 5px;
  }

  /* Responsive nhẹ */
  @media (max-width: 1024px) {
    .main-header-container {
      flex-wrap: wrap;
    }
    .search-box {
      margin-top: 10px;
      width: 100%;
    }
    .search-inner {
      width: 100%;
    }
    .search-input {
      width: 100%;
    }
  }
</style>