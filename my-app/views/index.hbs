{{> header}}

<!-- Hero Banner -->
<section class="hero-banner">
  <div class="hero-content">
    <img src="https://i.pinimg.com/736x/f4/ad/ba/f4adba58fd0ea1d06a5fe37958316074.jpg" 
         alt="Nike Day Slide" class="hero-image">
    
    <div class="hero-overlay">
      <div class="hero-text">
        <h1>DAY SLIDE</h1>
      </div>
    </div>
  </div>
</section>

<!-- Promo Section -->
<section class="promo-section">
  <div class="promo-container">
    
    <!-- Black & Black -->
    <div class="promo-card">
      <img src="https://i.pinimg.com/1200x/e7/1f/48/e71f480bd75e40b75dfb3b18e5611f45.jpg" 
           alt="Black & Black" class="promo-image">
      <div class="promo-info">
        <h2>BLACK & BLACK</h2>
        <p>Mặc dù được ứng dụng rất nhiều, nhưng sắc đen lúc nào cũng toát lên một vẻ huyền bí không nhàm chán.</p>
      </div>
    </div>

    <!-- Outlet Sale -->
    <div class="promo-card">
      <img src="https://i.pinimg.com/736x/34/4c/40/344c40ba3063ced3fc4aa95aea2f5c6d.jpg" 
           alt="Outlet Sale" class="promo-image">
      <div class="promo-info">
        <h2>OUTLET SALE</h2>
        <p>Danh mục những sản phẩm bán tại "giá tốt hơn" chỉ được bán trên kênh online. Online Only, chúng đã từng làm mưa làm gió một thời gian và hiện đang rơi vào tình trạng bế size, bế số.</p>
      </div>
    </div>

  </div>
</section>

<!-- Danh mục mua hàng -->
<section class="categories-section">
  <div class="section-title">
    <h2>DANH MỤC MUA HÀNG</h2>
  </div>

  <div class="categories-grid">
    
    <div class="category-card">
      <img src="https://i.pinimg.com/736x/cb/2c/44/cb2c4439240b38f6f813a6da77f84173.jpg" alt="Giày Nam">
      <div class="category-overlay">
        <h3>GIÀY NAM</h3>
        <ul>
          <li>New Arrivals</li>
          <li>Best Seller</li>
          <li>Sale-off</li>
        </ul>
      </div>
    </div>

    <div class="category-card">
      <img src="https://i.pinimg.com/1200x/05/05/fd/0505fd53e22be17b63eefa75cbe872b8.jpg" alt="Giày Nữ">
      <div class="category-overlay">
        <h3>GIÀY NỮ</h3>
        <ul>
          <li>New Arrivals</li>
          <li>Best Seller</li>
          <li>Sale-off</li>
        </ul>
      </div>
    </div>

    <div class="category-card">
      <img src="https://i.pinimg.com/736x/c7/4d/71/c74d7129d1b411faf5455d50337bf602.jpg" alt="Dòng sản phẩm">
      <div class="category-overlay">
        <h3>DÒNG SẢN PHẨM</h3>
        <ul>
          <li>Air Force 1</li>
          <li>Dunk</li>
          <li>Air Max</li>
          <li>Blazer</li>
        </ul>
      </div>
    </div>

  </div>
</section>

{{> footer}}