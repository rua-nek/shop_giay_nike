{{! views/register.hbs }}

<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - Shop Giày Nike</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Segoe UI", Roboto, system-ui, sans-serif;
        background: linear-gradient(145deg, #f5f7fa 0%, #e9ecf2 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
      }

      .register-card {
        background: #ffffff;
        max-width: 480px;
        width: 100%;
        padding: 2.5rem 2rem;
        border-radius: 32px;
        box-shadow:
          0 20px 40px -10px rgba(0, 0, 0, 0.12),
          0 8px 20px rgba(0, 0, 0, 0.05);
        transition: transform 0.2s ease;
      }

      .register-card:hover {
        transform: translateY(-3px);
      }

      .logo {
        text-align: center;
        margin-bottom: 1.5rem;
      }

      .logo svg {
        width: 50px;
        height: auto;
      }

      h1 {
        font-size: 1.9rem;
        font-weight: 700;
        color: #1a1e2b;
        text-align: center;
        margin-bottom: 0.5rem;
        letter-spacing: -0.5px;
      }

      .subhead {
        text-align: center;
        color: #6b7280;
        font-size: 0.95rem;
        margin-bottom: 1.8rem;
      }

      .form-group {
        margin-bottom: 1.2rem;
      }

      label {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 0.4rem;
      }

      .input-icon {
        position: relative;
      }

      .input-icon i {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        font-size: 1.1rem;
        pointer-events: none;
      }

      .input-icon input {
        width: 100%;
        padding: 0.85rem 1rem 0.85rem 2.8rem;
        font-size: 1rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 18px;
        background: #fafbfc;
        transition: all 0.2s;
        outline: none;
      }

      .input-icon input:focus {
        border-color: #111;
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(0, 0, 0, 0.03);
      }

      .input-icon input::placeholder {
        color: #b0b8c5;
        font-weight: 400;
      }

      /* Hàng hai cột cho số điện thoại và địa chỉ (tùy chọn) */
      .form-row {
        display: flex;
        gap: 0.8rem;
      }

      .form-row .form-group {
        flex: 1;
      }

      .btn-register {
        width: 100%;
        background: #111827;
        color: white;
        font-weight: 600;
        font-size: 1.05rem;
        padding: 0.95rem 1.5rem;
        border: none;
        border-radius: 40px;
        cursor: pointer;
        box-shadow: 0 6px 14px rgba(17, 24, 39, 0.2);
        transition: all 0.25s;
        letter-spacing: 0.3px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-top: 1.8rem;
      }

      .btn-register:hover {
        background: #000;
        transform: scale(1.01);
        box-shadow: 0 10px 18px rgba(0, 0, 0, 0.15);
      }

      .login-redirect {
        text-align: center;
        margin-top: 1.8rem;
        color: #4b5563;
        font-size: 0.95rem;
      }

      .login-redirect a {
        color: #111827;
        font-weight: 700;
        text-decoration: none;
        margin-left: 6px;
        border-bottom: 2px solid transparent;
        transition: border-color 0.2s;
      }

      .login-redirect a:hover {
        border-bottom-color: #111827;
      }

      .error-message {
        background: #fee2e2;
        color: #b91c1c;
        padding: 0.8rem 1rem;
        border-radius: 16px;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
        border-left: 5px solid #dc2626;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .field-error {
        color: #dc2626;
        font-size: 0.8rem;
        margin-top: 0.3rem;
        margin-left: 0.5rem;
      }

      .icon-symbol {
        font-size: 1.2rem;
        line-height: 1;
      }

      @media (max-width: 480px) {
        .register-card {
          padding: 2rem 1.5rem;
        }
        h1 {
          font-size: 1.7rem;
        }
        .form-row {
          flex-direction: column;
          gap: 0;
        }
      }
    </style>
  </head>
  <body>
    <div class="register-card">
      <div class="logo">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"
            fill="#111827"
          />
          <path
            d="M21.5 9L9.5 17.5L5 13"
            stroke="white"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </div>
      <h1>Đăng ký</h1>
      <div class="subhead">Tạo tài khoản để mua sắm dễ dàng hơn</div>

      {{#if error}}
        <div class="error-message">
          <span class="icon-symbol">⚠️</span>
          <span>{{error}}</span>
        </div>
      {{/if}}

      <form action="/user/register" method="POST">
        {{! Họ tên }}
        <div class="form-group">
          <label for="ho_ten">Họ và tên
            <span style="color:#dc2626;">*</span></label>
          <div class="input-icon">
            <i>👤</i>
            <input
              type="text"
              id="ho_ten"
              name="ho_ten"
              placeholder="Nguyễn Văn A"
              value="{{oldData.ho_ten}}"
              required
              autofocus
            />
          </div>
          {{#if errors.ho_ten}}<div
              class="field-error"
            >{{errors.ho_ten}}</div>{{/if}}
        </div>

        {{! Email }}
        <div class="form-group">
          <label for="email">Email <span style="color:#dc2626;">*</span></label>
          <div class="input-icon">
            <i>📧</i>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="example@email.com"
              value="{{oldData.email}}"
              required
            />
          </div>
          {{#if errors.email}}<div
              class="field-error"
            >{{errors.email}}</div>{{/if}}
        </div>

        {{! Mật khẩu và Xác nhận mật khẩu (2 cột) }}
        <div class="form-row">
          <div class="form-group">
            <label for="mat_khau">Mật khẩu
              <span style="color:#dc2626;">*</span></label>
            <div class="input-icon">
              <i>🔒</i>
              <input
                type="password"
                id="mat_khau"
                name="mat_khau"
                placeholder="••••••••"
                required
              />
            </div>
            {{#if errors.mat_khau}}<div
                class="field-error"
              >{{errors.mat_khau}}</div>{{/if}}
          </div>
          <div class="form-group">
            <label for="xac_nhan_mat_khau">Xác nhận MK
              <span style="color:#dc2626;">*</span></label>
            <div class="input-icon">
              <i>🔐</i>
              <input
                type="password"
                id="xac_nhan_mat_khau"
                name="xac_nhan_mat_khau"
                placeholder="••••••••"
                required
              />
            </div>
          </div>
        </div>
        {{#if errors.xac_nhan_mat_khau}}<div
            class="field-error"
          >{{errors.xac_nhan_mat_khau}}</div>{{/if}}

        {{! Số điện thoại và Địa chỉ (2 cột, không bắt buộc) }}
        <div class="form-row">
          <div class="form-group">
            <label for="so_dien_thoai">Số điện thoại</label>
            <div class="input-icon">
              <i>📱</i>
              <input
                type="tel"
                id="so_dien_thoai"
                name="so_dien_thoai"
                placeholder="0912345678"
                value="{{oldData.so_dien_thoai}}"
              />
            </div>
          </div>
          <div class="form-group">
            <label for="dia_chi">Địa chỉ</label>
            <div class="input-icon">
              <i>🏠</i>
              <input
                type="text"
                id="dia_chi"
                name="dia_chi"
                placeholder="Số nhà, đường, thành phố"
                value="{{oldData.dia_chi}}"
              />
            </div>
          </div>
        </div>

        <button type="submit" class="btn-register">
          <span>Đăng ký</span>
          <span style="font-size:1.2rem;">→</span>
        </button>

        <div class="login-redirect">
          Đã có tài khoản?
          <a href="/user/login">Đăng nhập ngay</a>
        </div>
      </form>
    </div>

    <script>
      window.onload = function() { const nameInput =
      document.getElementById('ho_ten'); if (nameInput) { nameInput.focus(); if
      (nameInput.value.length > 0) {
      nameInput.setSelectionRange(nameInput.value.length,
      nameInput.value.length); } } };
    </script>
  </body>
</html>